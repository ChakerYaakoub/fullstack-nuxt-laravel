{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~": ["./app"],
      "~/*": ["./app/*"],
      "@": ["./app"],
      "@/*": ["./app/*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "#imports": ["./.nuxt/imports"],
      "#app": ["./node_modules/nuxt/dist/app"],
      "#app/*": ["./node_modules/nuxt/dist/app/*"],
      "#vue-router": ["./node_modules/vue-router"],
      "#components": ["./.nuxt/components"],
      "#build": ["./.nuxt"],
      "#build/*": ["./.nuxt/*"]
    }
  }
}
